# Terraform — state contains secrets in plaintext
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfvars
terraform.tfstate
terraform.tfstate.*
terraform/.terraform.lock.hcl   # optional: keep this one if you want pinned providers

# Ansible — generated inventory + the kubeconfig + vault password
ansible/inventory.ini
kubeconfig
.vault_pass
*.vault_pass*

# SSH keys
*.pem

# Generated by show-links.sh — contains session-specific IPs
links.html

# Python
__pycache__/
*.pyc
.venv/
.env
